{
  "$schema": "https://opencode.ai/config.json",
  // "enabled_providers": [
  //   "deepseek",
  //   "openrouter",
  //   "openai"
  // ],
  "skills": {
    "paths": [
      ".agents/skills"
    ]
  },
  "agent": {
    "brainstormer": {
      "model": "openai/gpt-5.4"
    },
    "planner": {
      "model": "openai/gpt-5.4"
    },
    "plan-reviewer": {
      "model": "openai/gpt-5.5"
    },
    "implementor": {
      "model": "deepseek/deepseek-v4-pro"
    },
    "reviewer": {
      "model": "openai/gpt-5.5"
    },
    "tester": {
      "model": "deepseek/deepseek-v4-flash"
    },
    "linter": {
      "model": "deepseek/deepseek-v4-flash"
    },
    "commit-message": {
      "model": "deepseek/deepseek-v4-pro"
    }
  },
  "mcp": {
    "atlassian": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/mcp"
      ],
      "enabled": true
    }
  }
}